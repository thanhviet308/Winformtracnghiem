<?xml version="1.0" encoding="utf-8"?>
<!-- Self-contained single-file publish for WinForms (.NET 8) -->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>D:\.net\build\singlefile\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Create a standalone .exe that runs without installing .NET -->
    <SelfContained>true</SelfContained>
    <!-- Produce a single exe (contents will self-extract if needed) -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Startup/perf -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <!-- WinForms apps often break with trimming -->
    <!-- Cleaner output -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <!-- Ensure icon is embedded in single-file exe -->
    <ApplicationIcon>Assets\Icon\app.ico</ApplicationIcon>
  </PropertyGroup>
</Project>